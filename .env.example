# ============================================
# REDSTONE MVP - ENVIRONMENT VARIABLES
# ============================================
# Copy this to backend/.env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
# For production: NODE_ENV=production

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
# Get from https://supabase.com after creating a project
# DATABASE_URL format: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=your_supabase_database_url_here
DATABASE_DIRECT_URL=your_supabase_direct_url_here  # For migrations

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================
# GROQ API (LLM for Pulse Generation)
# ============================================
# Get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ============================================
# OPENAI API (Embeddings)
# ============================================
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Alternative: text-embedding-3-large (more expensive)

# ============================================
# SLACK INTEGRATION
# ============================================
# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_REDIRECT_URI=https://your-domain.com/api/slack/oauth/callback
# For local testing: http://localhost:3001/api/slack/oauth/callback

# ============================================
# GOOGLE OAUTH (Gmail + Calendar)
# ============================================
# Get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google/oauth/callback
# For local testing: http://localhost:3001/api/google/oauth/callback

# ============================================
# STRIPE (For Payments - Later Phase)
# ============================================
# Get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:8000
# For production: FRONTEND_URL=https://your-domain.com

# ============================================
# OPTIONAL: ERROR TRACKING
# ============================================
# SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id

# ============================================
# OPTIONAL: EMAIL SERVICE (For Notifications)
# ============================================
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ============================================
# HOW TO GET EACH KEY
# ============================================
# 
# SUPABASE DATABASE:
#   1. Go to https://supabase.com
#   2. Create new project (free tier available)
#   3. Go to Settings > Database
#   4. Copy connection string to DATABASE_URL
#
# GROQ API KEY:
#   1. Go to https://console.groq.com
#   2. Sign in with Google
#   3. Create API key
#   4. Copy key to GROQ_API_KEY
#
# OPENAI API KEY:
#   1. Go to https://platform.openai.com/api-keys
#   2. Click "Create new secret key"
#   3. Copy to OPENAI_API_KEY
#
# SLACK BOT TOKEN:
#   1. Go to https://api.slack.com/apps
#   2. Create New App (from manifest)
#   3. Use template in docs/slack-app-manifest.json
#   4. Go to OAuth & Permissions
#   5. Copy Bot User OAuth Token (xoxb-...) to SLACK_BOT_TOKEN
#   6. Copy Signing Secret to SLACK_SIGNING_SECRET
#
# GOOGLE OAUTH:
#   1. Go to https://console.cloud.google.com
#   2. Create new project
#   3. Enable Gmail & Calendar APIs
#   4. Go to Credentials > Create OAuth 2.0 Client ID
#   5. Choose "Web application"
#   6. Add redirect URIs:
#      - http://localhost:3001/api/google/oauth/callback (dev)
#      - https://your-domain.com/api/google/oauth/callback (prod)
#   7. Download JSON, copy Client ID & Secret
#
# STRIPE KEYS:
#   1. Go to https://dashboard.stripe.com/apikeys
#   2. Copy Secret Key to STRIPE_SECRET_KEY
#   3. Copy Publishable Key to STRIPE_PUBLISHABLE_KEY
#

# ============================================
# NOTES
# ============================================
#
# DEVELOPMENT:
#   - NODE_ENV=development uses in-memory mock data
#   - No need for DATABASE_URL in dev mode
#   - API keys can be empty (mock responses used)
#
# PRODUCTION:
#   - Set NODE_ENV=production
#   - All keys are required
#   - DATABASE_URL must be valid
#   - Use strong JWT_SECRET (min 32 chars)
#   - All HTTPS URLs required
#
# LOCAL TESTING:
#   - Use http://localhost:3001 for REDIRECT_URIs
#   - Mock data works without real API keys
#   - Just fill in the ones you're testing
#
