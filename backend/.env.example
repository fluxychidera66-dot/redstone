# ============================================================
# REDSTONE - ENVIRONMENT VARIABLES
# Copy this to .env and fill in all values
# ============================================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Auth
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Google OAuth (for login + Gmail + Calendar)
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Slack
SLACK_CLIENT_ID=REPLACE_WITH_SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=REPLACE_WITH_SLACK_CLIENT_SECRET
SLACK_SIGNING_SECRET=REPLACE_WITH_SLACK_SIGNING_SECRET
SLACK_BOT_TOKEN=REPLACE_WITH_SLACK_BOT_TOKEN
SLACK_REDIRECT_URI=http://localhost:3001/auth/slack/callback

# Groq (LLM)
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# OpenAI (Embeddings only)
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# Stripe
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_BASIC=REPLACE_WITH_STRIPE_PRICE_ID_BASIC_30
STRIPE_PRICE_PRO=REPLACE_WITH_STRIPE_PRICE_ID_PRO_80
STRIPE_PRICE_BUSINESS=REPLACE_WITH_STRIPE_PRICE_ID_BUSINESS_250
